# Generation: default is local Llama GGUF (see download_llm.py). Use openai for cloud.
# LLM_BACKEND=local
# LLM_BACKEND=openai

# Optional: path to any compatible Llama / llama.cpp GGUF you already have
# LOCAL_LLAMA_PATH=/path/to/model.gguf

# OpenAI (only when LLM_BACKEND=openai or --backend openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Hugging Face token (only if a gated model download fails)
# HF_TOKEN=

# Local Llama runtime (defaults are fine on CPU)
# LLAMA_N_CTX=8192
# LLAMA_N_GPU_LAYERS=0
# LLAMA_MAX_TOKENS=512
# LLAMA_TEMPERATURE=0.2

# Web UI (python web_app.py)
# RAG_WEB_HOST=127.0.0.1
# RAG_WEB_PORT=8765

# Documents: resources/documents/ (see resources/document_catalog.json after ingest)

# Streamlit UI: streamlit run streamlit_app.py
# PUBLIC_DEMO_MODE=1      # hide document names and retrieved chunks
# SHOW_DOC_METADATA=0     # show catalog table only when 1 and PUBLIC_DEMO_MODE=0
# ALLOW_USER_UPLOAD=0     # set 1 only if you want visitors to upload files
# ALLOW_USER_REINDEX=0    # set 1 only if you want visitors to trigger reindex
